{
  "name": "niclaslindstedt.se",
  "private": true,
  "version": "0.0.1",
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && npm run generate:sitemap",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc -b --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate:cv": "ajv validate -c ajv-formats --spec=draft2020 --strict=false -s schemas/cv.schema.json -d src/data/cv.json",
    "validate:skill-tags": "node scripts/validate-skill-tags.mjs",
    "validate:timeline-json": "node scripts/validate-timeline-json.mjs",
    "generate:timeline": "node scripts/generate-timeline.mjs",
    "generate:github-activity": "node scripts/generate-github-activity.mjs",
    "generate:project-stats": "node scripts/generate-project-stats.mjs",
    "generate:og": "node scripts/generate-og-image.mjs",
    "generate:sitemap": "node scripts/generate-sitemap.mjs",
    "generate:data": "node scripts/generate-github-activity.mjs && node scripts/generate-project-stats.mjs && node scripts/generate-timeline.mjs",
    "postinstall": "npm run generate:data",
    "prebuild": "npm run generate:data && npm run generate:og",
    "predev": "npm run generate:data",
    "pretypecheck": "npm run generate:data",
    "prelint": "npm run generate:data"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@fontsource/inter": "^5.2.8",
    "@resvg/resvg-js": "^2.6.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "ajv": "^8.18.0",
    "ajv-cli": "^5.0.0",
    "ajv-formats": "^3.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "satori": "^0.26.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^5.4.11",
    "wawoff2": "^2.0.1"
  }
}
