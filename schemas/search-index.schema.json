{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://niclaslindstedt.se/schemas/search-index.schema.json",
  "title": "Search index",
  "description": "Flat denormalised list of searchable CV records, baked at build time and consumed by the in-page fuzzy search.",
  "type": "object",
  "additionalProperties": false,
  "required": ["generatedAt", "records"],
  "properties": {
    "generatedAt": { "type": "string", "format": "date-time" },
    "records": {
      "type": "array",
      "items": { "$ref": "#/$defs/record" }
    }
  },
  "$defs": {
    "kind": {
      "type": "string",
      "enum": [
        "project",
        "company",
        "experience",
        "assignment",
        "education",
        "course",
        "skill",
        "focus",
        "summary"
      ]
    },
    "lang": {
      "type": "string",
      "enum": ["en", "sv"]
    },
    "localizedString": {
      "type": "object",
      "additionalProperties": false,
      "required": ["en", "sv"],
      "properties": {
        "en": { "type": "string" },
        "sv": { "type": "string" }
      }
    },
    "record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "openerKey", "title", "lang", "haystack"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": { "$ref": "#/$defs/kind" },
        "openerKey": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "secondary": { "type": "string" },
        "lang": { "$ref": "#/$defs/lang" },
        "haystack": { "type": "string", "minLength": 1 },
        "localizedTitle": { "$ref": "#/$defs/localizedString" },
        "localizedSecondary": { "$ref": "#/$defs/localizedString" }
      }
    }
  }
}
