{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://niclaslindstedt.se/schemas/timeline.schema.json",
  "title": "Timeline layout",
  "description": "Precomputed career-timeline layout generated from cv.json.",
  "type": "object",
  "additionalProperties": false,
  "required": ["minMonth", "maxMonth", "intervals", "tracks"],
  "properties": {
    "minMonth": { "type": "integer" },
    "maxMonth": { "type": "integer" },
    "intervals": {
      "type": "array",
      "items": { "$ref": "#/$defs/interval" }
    },
    "tracks": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/track" }
    }
  },
  "$defs": {
    "kind": {
      "type": "string",
      "enum": ["experience", "assignment", "education", "github"]
    },
    "isoMonth": {
      "type": "string",
      "pattern": "^\\d{4}-(0[1-9]|1[0-2])$"
    },
    "interval": {
      "type": "object",
      "additionalProperties": false,
      "required": ["startMonth", "endMonth", "trackActiveCounts"],
      "properties": {
        "startMonth": { "type": "integer" },
        "endMonth": { "type": "integer" },
        "trackActiveCounts": {
          "type": "array",
          "items": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "track": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "label", "bars"],
      "properties": {
        "key": { "$ref": "#/$defs/kind" },
        "label": { "type": "string", "minLength": 1 },
        "bars": {
          "type": "array",
          "items": { "$ref": "#/$defs/bar" }
        }
      }
    },
    "bar": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "title",
        "subtitle",
        "description",
        "skills",
        "startDate",
        "endDate",
        "isOngoing",
        "endMonthAtBuild",
        "segments"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": { "$ref": "#/$defs/kind" },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "description": { "type": "string" },
        "skills": {
          "type": "array",
          "items": { "type": "string" }
        },
        "startDate": { "$ref": "#/$defs/isoMonth" },
        "endDate": {
          "oneOf": [{ "$ref": "#/$defs/isoMonth" }, { "type": "null" }]
        },
        "isOngoing": { "type": "boolean" },
        "endMonthAtBuild": { "type": "integer" },
        "segments": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/segment" }
        },
        "github": { "$ref": "#/$defs/github" }
      }
    },
    "github": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "totalCommits",
        "dailyCommits",
        "busiestMonth",
        "busiestMonthCount",
        "busiestWeekStart",
        "busiestWeekCount",
        "busiestDay",
        "busiestDayCount",
        "profileUrl",
        "username",
        "maxDailyCommits"
      ],
      "properties": {
        "totalCommits": { "type": "integer", "minimum": 0 },
        "dailyCommits": {
          "type": "array",
          "items": { "type": "integer", "minimum": 0 }
        },
        "busiestMonth": { "type": "integer", "minimum": 1, "maximum": 12 },
        "busiestMonthCount": { "type": "integer", "minimum": 0 },
        "busiestWeekStart": {
          "type": "string",
          "pattern": "^\\d{4}-(0[1-9]|1[0-2])-(0[1-9]|[12]\\d|3[01])$"
        },
        "busiestWeekCount": { "type": "integer", "minimum": 0 },
        "busiestDay": {
          "type": "string",
          "pattern": "^\\d{4}-(0[1-9]|1[0-2])-(0[1-9]|[12]\\d|3[01])$"
        },
        "busiestDayCount": { "type": "integer", "minimum": 0 },
        "profileUrl": { "type": "string", "minLength": 1 },
        "username": { "type": "string", "minLength": 1 },
        "maxDailyCommits": { "type": "integer", "minimum": 0 }
      }
    },
    "segment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["startMonth", "endMonth", "activeLane"],
      "properties": {
        "startMonth": { "type": "integer" },
        "endMonth": { "type": "integer" },
        "activeLane": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
