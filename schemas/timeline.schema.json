{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://niclaslindstedt.se/schemas/timeline.schema.json",
  "title": "Timeline layout",
  "description": "Precomputed career-timeline layout generated from cv.json.",
  "type": "object",
  "additionalProperties": false,
  "required": ["minMonth", "maxMonth", "tracks"],
  "properties": {
    "minMonth": { "type": "integer" },
    "maxMonth": { "type": "integer" },
    "tracks": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/track" }
    }
  },
  "$defs": {
    "kind": {
      "type": "string",
      "enum": ["experience", "assignment", "education"]
    },
    "isoMonth": {
      "type": "string",
      "pattern": "^\\d{4}-(0[1-9]|1[0-2])$"
    },
    "track": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "label", "lanes", "bars"],
      "properties": {
        "key": { "$ref": "#/$defs/kind" },
        "label": { "type": "string", "minLength": 1 },
        "lanes": { "type": "integer", "minimum": 1 },
        "bars": {
          "type": "array",
          "items": { "$ref": "#/$defs/bar" }
        }
      }
    },
    "bar": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "lane",
        "title",
        "subtitle",
        "description",
        "skills",
        "startDate",
        "endDate",
        "isOngoing",
        "endMonthAtBuild"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": { "$ref": "#/$defs/kind" },
        "lane": { "type": "integer", "minimum": 0 },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "description": { "type": "string" },
        "skills": {
          "type": "array",
          "items": { "type": "string" }
        },
        "startDate": { "$ref": "#/$defs/isoMonth" },
        "endDate": {
          "oneOf": [{ "$ref": "#/$defs/isoMonth" }, { "type": "null" }]
        },
        "isOngoing": { "type": "boolean" },
        "endMonthAtBuild": { "type": "integer" }
      }
    }
  }
}
