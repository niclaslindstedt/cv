{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://niclaslindstedt.se/schemas/cv.schema.json",
  "title": "CV",
  "description": "Personal CV content for niclaslindstedt.se.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "meta",
    "name",
    "title",
    "location",
    "summary",
    "links",
    "actions",
    "sections",
    "focus",
    "projects",
    "companies",
    "experience",
    "education",
    "courses",
    "skills"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "meta": { "$ref": "#/$defs/meta" },
    "name": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "location": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "links": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/link" }
    },
    "actions": { "$ref": "#/$defs/actions" },
    "sections": { "$ref": "#/$defs/sections" },
    "focus": {
      "type": "array",
      "items": { "$ref": "#/$defs/focusArea" }
    },
    "projects": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/project" }
    },
    "companies": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/company" }
    },
    "experience": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/experience" }
    },
    "education": {
      "type": "array",
      "items": { "$ref": "#/$defs/education" }
    },
    "courses": {
      "type": "array",
      "items": { "$ref": "#/$defs/course" }
    },
    "skills": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/skillGroup" }
    }
  },
  "$defs": {
    "yearMonth": {
      "type": "string",
      "pattern": "^\\d{4}-(0[1-9]|1[0-2])$",
      "description": "Year and month in YYYY-MM format."
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["documentTitle", "description"],
      "properties": {
        "documentTitle": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 }
      }
    },
    "link": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "url"],
      "properties": {
        "label": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "format": "uri" },
        "featured": { "type": "boolean" }
      }
    },
    "actions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["timeline", "downloadPdf"],
      "properties": {
        "timeline": { "type": "string", "minLength": 1 },
        "downloadPdf": { "type": "string", "minLength": 1 }
      }
    },
    "sections": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "focus",
        "projects",
        "experience",
        "education",
        "courses",
        "skills"
      ],
      "properties": {
        "focus": { "type": "string", "minLength": 1 },
        "projects": { "type": "string", "minLength": 1 },
        "experience": { "type": "string", "minLength": 1 },
        "education": { "type": "string", "minLength": 1 },
        "courses": { "type": "string", "minLength": 1 },
        "skills": { "type": "string", "minLength": 1 }
      }
    },
    "focusArea": {
      "type": "object",
      "additionalProperties": false,
      "required": ["area", "since"],
      "properties": {
        "area": { "type": "string", "minLength": 1 },
        "since": { "$ref": "#/$defs/yearMonth" }
      }
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "tagline", "description", "skills", "repo"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "tagline": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "stack": { "$ref": "#/$defs/stringList" },
        "skills": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "repo": { "type": "string", "format": "uri" }
      }
    },
    "company": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "description"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$",
          "description": "Stable slug used to reference this company from experience/assignment entries."
        },
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "format": "uri" },
        "terminated": { "type": "boolean" },
        "stack": { "$ref": "#/$defs/stringList" }
      }
    },
    "experience": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role", "companyId", "startDate", "endDate"],
      "properties": {
        "role": { "type": "string", "minLength": 1 },
        "companyId": { "type": "string", "minLength": 1 },
        "startDate": { "$ref": "#/$defs/yearMonth" },
        "endDate": {
          "oneOf": [{ "$ref": "#/$defs/yearMonth" }, { "type": "null" }]
        },
        "engagement": { "type": "string", "minLength": 1 },
        "stack": { "$ref": "#/$defs/stringList" },
        "skills": { "$ref": "#/$defs/stringList" },
        "assignments": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/assignment" }
        }
      }
    },
    "assignment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role", "clientId", "startDate", "endDate"],
      "properties": {
        "role": { "type": "string", "minLength": 1 },
        "clientId": { "type": "string", "minLength": 1 },
        "startDate": { "$ref": "#/$defs/yearMonth" },
        "endDate": {
          "oneOf": [{ "$ref": "#/$defs/yearMonth" }, { "type": "null" }]
        },
        "stack": { "$ref": "#/$defs/stringList" },
        "skills": { "$ref": "#/$defs/stringList" }
      }
    },
    "education": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "field",
        "institution",
        "level",
        "credits",
        "startDate",
        "endDate"
      ],
      "properties": {
        "field": { "type": "string", "minLength": 1 },
        "institution": { "type": "string", "minLength": 1 },
        "level": { "type": "string", "minLength": 1 },
        "credits": { "type": "string", "minLength": 1 },
        "startDate": { "$ref": "#/$defs/yearMonth" },
        "endDate": { "$ref": "#/$defs/yearMonth" },
        "skills": { "$ref": "#/$defs/stringList" }
      }
    },
    "course": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "code", "institution", "credits", "completedDate"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "code": { "type": "string", "minLength": 1 },
        "institution": { "type": "string", "minLength": 1 },
        "credits": { "type": "string", "minLength": 1 },
        "completedDate": { "$ref": "#/$defs/yearMonth" },
        "skills": { "$ref": "#/$defs/stringList" }
      }
    },
    "skillGroup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "label", "items"],
      "properties": {
        "key": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "items": { "$ref": "#/$defs/stringList" }
      }
    },
    "stringList": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
