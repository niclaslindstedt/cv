{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://niclaslindstedt.se/schemas/cv.schema.json",
  "title": "CV",
  "description": "Personal CV content for niclaslindstedt.se.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "title",
    "location",
    "links",
    "summary",
    "focus",
    "projects",
    "experience",
    "education",
    "skills"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "name": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "location": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "links": {
      "type": "object",
      "additionalProperties": false,
      "required": ["linkedin", "github", "blog"],
      "properties": {
        "linkedin": { "type": "string", "format": "uri" },
        "github": { "type": "string", "format": "uri" },
        "blog": { "type": "string", "format": "uri" }
      }
    },
    "focus": {
      "type": "array",
      "items": { "$ref": "#/$defs/focusArea" }
    },
    "projects": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/project" }
    },
    "experience": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/experience" }
    },
    "education": {
      "type": "array",
      "items": { "$ref": "#/$defs/education" }
    },
    "skills": { "$ref": "#/$defs/skills" }
  },
  "$defs": {
    "yearMonth": {
      "type": "string",
      "pattern": "^\\d{4}-(0[1-9]|1[0-2])$",
      "description": "Year and month in YYYY-MM format."
    },
    "focusArea": {
      "type": "object",
      "additionalProperties": false,
      "required": ["area", "since"],
      "properties": {
        "area": { "type": "string", "minLength": 1 },
        "since": { "$ref": "#/$defs/yearMonth" }
      }
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "tagline", "description", "skills", "repo"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "tagline": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "skills": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "repo": { "type": "string", "format": "uri" }
      }
    },
    "experience": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "role",
        "company",
        "companyDescription",
        "startDate",
        "endDate"
      ],
      "properties": {
        "role": { "type": "string", "minLength": 1 },
        "company": { "type": "string", "minLength": 1 },
        "companyDescription": { "type": "string", "minLength": 1 },
        "startDate": { "$ref": "#/$defs/yearMonth" },
        "endDate": {
          "oneOf": [{ "$ref": "#/$defs/yearMonth" }, { "type": "null" }]
        },
        "engagement": { "type": "string", "minLength": 1 },
        "skills": { "$ref": "#/$defs/stringList" },
        "assignments": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/assignment" }
        }
      }
    },
    "assignment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "role",
        "client",
        "clientDescription",
        "startDate",
        "endDate"
      ],
      "properties": {
        "role": { "type": "string", "minLength": 1 },
        "client": { "type": "string", "minLength": 1 },
        "clientDescription": { "type": "string", "minLength": 1 },
        "startDate": { "$ref": "#/$defs/yearMonth" },
        "endDate": {
          "oneOf": [{ "$ref": "#/$defs/yearMonth" }, { "type": "null" }]
        },
        "skills": { "$ref": "#/$defs/stringList" }
      }
    },
    "education": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "field",
        "institution",
        "level",
        "credits",
        "startDate",
        "endDate"
      ],
      "properties": {
        "field": { "type": "string", "minLength": 1 },
        "institution": { "type": "string", "minLength": 1 },
        "level": { "type": "string", "minLength": 1 },
        "credits": { "type": "string", "minLength": 1 },
        "startDate": { "$ref": "#/$defs/yearMonth" },
        "endDate": { "$ref": "#/$defs/yearMonth" },
        "skills": { "$ref": "#/$defs/stringList" }
      }
    },
    "skills": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "languages",
        "frameworks",
        "cloud",
        "databases",
        "ai",
        "devops"
      ],
      "properties": {
        "languages": { "$ref": "#/$defs/stringList" },
        "frameworks": { "$ref": "#/$defs/stringList" },
        "cloud": { "$ref": "#/$defs/stringList" },
        "databases": { "$ref": "#/$defs/stringList" },
        "ai": { "$ref": "#/$defs/stringList" },
        "devops": { "$ref": "#/$defs/stringList" }
      }
    },
    "stringList": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
