{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://niclaslindstedt.se/schemas/cv.schema.json",
  "title": "CV",
  "description": "Personal CV content for niclaslindstedt.se.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "meta",
    "name",
    "title",
    "summary",
    "longSummary",
    "links",
    "actions",
    "sections",
    "focus",
    "projects",
    "companies",
    "experience",
    "education",
    "courses",
    "skills",
    "skillDetails",
    "languages"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "meta": { "$ref": "#/$defs/meta" },
    "name": { "type": "string", "minLength": 1 },
    "title": { "$ref": "#/$defs/localizedString" },
    "summary": {
      "$ref": "#/$defs/localizedString",
      "description": "Short headline (~2 sentences) that says where the author is now and where they are going. Rendered as the clickable hero summary."
    },
    "longSummary": {
      "$ref": "#/$defs/localizedString",
      "description": "Longer narrative summary of the CV without boring details. Revealed when the user clicks the hero summary."
    },
    "links": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/link" }
    },
    "actions": { "$ref": "#/$defs/actions" },
    "sections": { "$ref": "#/$defs/sections" },
    "focus": {
      "type": "array",
      "items": { "$ref": "#/$defs/focusArea" }
    },
    "projects": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/project" }
    },
    "companies": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/company" }
    },
    "experience": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/experience" }
    },
    "education": {
      "type": "array",
      "items": { "$ref": "#/$defs/education" }
    },
    "courses": {
      "type": "array",
      "items": { "$ref": "#/$defs/course" }
    },
    "skills": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/skillGroup" }
    },
    "skillDetails": {
      "type": "object",
      "description": "Per-skill metadata keyed by skill name (must match strings used in skills/items, projects, experience, etc.).",
      "additionalProperties": { "$ref": "#/$defs/skillDetail" }
    },
    "languages": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/spokenLanguage" }
    }
  },
  "$defs": {
    "yearMonth": {
      "type": "string",
      "pattern": "^\\d{4}-(0[1-9]|1[0-2])$",
      "description": "Year and month in YYYY-MM format."
    },
    "localizedString": {
      "type": "object",
      "additionalProperties": false,
      "required": ["en", "sv"],
      "properties": {
        "en": { "type": "string", "minLength": 1 },
        "sv": { "type": "string", "minLength": 1 }
      },
      "description": "Translatable string. Must supply both English and Swedish copy."
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["siteUrl", "documentTitle", "description", "seo"],
      "properties": {
        "siteUrl": {
          "type": "string",
          "format": "uri",
          "description": "Canonical absolute URL of the deployed site, used to build canonical/OG links and the sitemap."
        },
        "documentTitle": { "$ref": "#/$defs/localizedString" },
        "description": { "$ref": "#/$defs/localizedString" },
        "seo": { "$ref": "#/$defs/seo" }
      }
    },
    "seo": {
      "type": "object",
      "additionalProperties": false,
      "required": ["keywords", "image", "locale", "alternateLocale"],
      "properties": {
        "keywords": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "description": "Keyword list rendered as <meta name=\"keywords\"> and passed to JSON-LD."
        },
        "image": {
          "type": "string",
          "minLength": 1,
          "description": "Site-relative path to the social/OG image (resolved against meta.siteUrl)."
        },
        "locale": {
          "type": "string",
          "pattern": "^[a-z]{2}_[A-Z]{2}$",
          "description": "Primary OG locale (e.g. en_US)."
        },
        "alternateLocale": {
          "type": "string",
          "pattern": "^[a-z]{2}_[A-Z]{2}$",
          "description": "Secondary OG locale advertised via og:locale:alternate (e.g. sv_SE)."
        }
      }
    },
    "link": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "url"],
      "properties": {
        "label": { "$ref": "#/$defs/localizedString" },
        "url": { "type": "string", "format": "uri" },
        "featured": { "type": "boolean" }
      }
    },
    "actions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["timeline", "downloadPdf"],
      "properties": {
        "timeline": { "$ref": "#/$defs/localizedString" },
        "downloadPdf": { "$ref": "#/$defs/localizedString" }
      }
    },
    "sections": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "focus",
        "projects",
        "experience",
        "education",
        "courses",
        "skills",
        "languages"
      ],
      "properties": {
        "focus": { "$ref": "#/$defs/localizedString" },
        "projects": { "$ref": "#/$defs/localizedString" },
        "experience": { "$ref": "#/$defs/localizedString" },
        "education": { "$ref": "#/$defs/localizedString" },
        "courses": { "$ref": "#/$defs/localizedString" },
        "skills": { "$ref": "#/$defs/localizedString" },
        "languages": { "$ref": "#/$defs/localizedString" }
      }
    },
    "focusArea": {
      "type": "object",
      "additionalProperties": false,
      "required": ["area", "since", "description"],
      "properties": {
        "area": { "$ref": "#/$defs/localizedString" },
        "since": { "$ref": "#/$defs/yearMonth" },
        "description": { "$ref": "#/$defs/localizedString" }
      }
    },
    "skillDetail": {
      "type": "object",
      "additionalProperties": false,
      "required": ["description"],
      "properties": {
        "description": { "$ref": "#/$defs/localizedString" },
        "benefits": { "$ref": "#/$defs/localizedString" },
        "drawbacks": { "$ref": "#/$defs/localizedString" },
        "url": { "type": "string", "format": "uri" }
      }
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "tagline",
        "description",
        "skills",
        "github",
        "openSource"
      ],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "tagline": { "$ref": "#/$defs/localizedString" },
        "description": { "$ref": "#/$defs/localizedString" },
        "stack": { "$ref": "#/$defs/stringList" },
        "skills": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "github": {
          "type": "object",
          "additionalProperties": false,
          "required": ["owner", "repo"],
          "properties": {
            "owner": {
              "type": "string",
              "pattern": "^[A-Za-z0-9][A-Za-z0-9-]*$"
            },
            "repo": {
              "type": "string",
              "pattern": "^[A-Za-z0-9._-]+$"
            }
          },
          "description": "Identifies the GitHub repository used to fetch commit stats at build time. The owner/repo pair is also used to derive the public link when openSource is true."
        },
        "openSource": {
          "type": "boolean",
          "description": "Whether the repository is publicly accessible. When true, the project renders an open-source pill and a link to github.com/{owner}/{repo}; when false, only description, dates, and commit stats are shown."
        },
        "homepage": {
          "type": "string",
          "format": "uri",
          "description": "Public homepage for the project (e.g. a deployed site or hosted documentation). When set, the project modal renders a link to it."
        }
      }
    },
    "company": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "tagline", "description"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$",
          "description": "Stable slug used to reference this company from experience/assignment entries."
        },
        "name": { "type": "string", "minLength": 1 },
        "tagline": { "$ref": "#/$defs/localizedString" },
        "description": { "$ref": "#/$defs/localizedString" },
        "url": { "type": "string", "format": "uri" },
        "terminated": { "type": "boolean" },
        "stack": { "$ref": "#/$defs/stringList" },
        "sourceUrls": {
          "type": "array",
          "minItems": 1,
          "description": "Reference URLs the `update-company-descriptions` skill consults when rewriting `tagline` and `description`. Not rendered on the site.",
          "items": { "$ref": "#/$defs/sourceUrl" }
        }
      }
    },
    "sourceUrl": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "url", "description"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "format": "uri" },
        "description": { "type": "string", "minLength": 1 }
      }
    },
    "roleTenure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "startDate", "endDate"],
      "description": "A title held within a single tenure (job or assignment). Multiple entries in a parent's roles[] represent internal promotions or title changes that do not break the continuity of the parent.",
      "properties": {
        "title": { "$ref": "#/$defs/localizedString" },
        "startDate": { "$ref": "#/$defs/yearMonth" },
        "endDate": {
          "oneOf": [{ "$ref": "#/$defs/yearMonth" }, { "type": "null" }]
        }
      }
    },
    "experience": {
      "type": "object",
      "additionalProperties": false,
      "required": ["roles", "companyId", "startDate", "endDate"],
      "properties": {
        "roles": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/roleTenure" },
          "description": "One entry per title held during this employment, ordered by startDate ascending. Multiple entries represent promotions; the parent's startDate/endDate must equal the first/last role's startDate/endDate."
        },
        "companyId": { "type": "string", "minLength": 1 },
        "startDate": { "$ref": "#/$defs/yearMonth" },
        "endDate": {
          "oneOf": [{ "$ref": "#/$defs/yearMonth" }, { "type": "null" }]
        },
        "engagement": { "$ref": "#/$defs/localizedString" },
        "stack": { "$ref": "#/$defs/stringList" },
        "skills": { "$ref": "#/$defs/stringList" },
        "notes": { "$ref": "#/$defs/localizedString" },
        "assignments": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/assignment" }
        }
      }
    },
    "assignment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["roles", "clientId", "startDate", "endDate"],
      "properties": {
        "roles": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/roleTenure" },
          "description": "One entry per title held during this client engagement, ordered by startDate ascending. Multiple entries represent promotions within the same continuous assignment."
        },
        "clientId": { "type": "string", "minLength": 1 },
        "startDate": { "$ref": "#/$defs/yearMonth" },
        "endDate": {
          "oneOf": [{ "$ref": "#/$defs/yearMonth" }, { "type": "null" }]
        },
        "stack": { "$ref": "#/$defs/stringList" },
        "skills": { "$ref": "#/$defs/stringList" },
        "notes": { "$ref": "#/$defs/localizedString" }
      }
    },
    "education": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "field",
        "institution",
        "level",
        "credits",
        "startDate",
        "endDate"
      ],
      "properties": {
        "field": { "$ref": "#/$defs/localizedString" },
        "institution": { "$ref": "#/$defs/localizedString" },
        "level": { "$ref": "#/$defs/localizedString" },
        "credits": { "type": "string", "minLength": 1 },
        "startDate": { "$ref": "#/$defs/yearMonth" },
        "endDate": { "$ref": "#/$defs/yearMonth" },
        "skills": { "$ref": "#/$defs/stringList" },
        "notes": { "$ref": "#/$defs/localizedString" },
        "courses": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/programCourse" }
        }
      }
    },
    "programCourse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "code", "credits"],
      "description": "A course in a program. Status semantics: (1) `completedDate` set ⇒ fully completed; (2) `completed: false` ⇒ not fully completed (renders an 'Incomplete' pill) — individual `moments[].completedDate` may still be set to record partial completion; (3) neither ⇒ in progress.",
      "properties": {
        "name": { "$ref": "#/$defs/localizedString" },
        "code": { "type": "string", "minLength": 1 },
        "credits": { "type": "string", "minLength": 1 },
        "completedDate": {
          "$ref": "#/$defs/yearMonth",
          "description": "Date the course was fully passed. Omit when the course was abandoned (`completed: false`) or is still in progress."
        },
        "grade": { "type": "string", "minLength": 1 },
        "completed": {
          "type": "boolean",
          "description": "Whether the course was fully completed. Defaults to true. Set to false when the course was abandoned; partially-completed `moments[]` may still carry `completedDate`."
        },
        "moments": {
          "type": "array",
          "minItems": 1,
          "description": "Sub-parts (Swedish: \"moment\") that make up the course. Use to break down vague course names or to record partial completion when `completed: false`.",
          "items": { "$ref": "#/$defs/courseMoment" }
        },
        "skills": { "$ref": "#/$defs/stringList" }
      }
    },
    "courseMoment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "credits"],
      "properties": {
        "name": { "$ref": "#/$defs/localizedString" },
        "code": { "type": "string", "minLength": 1 },
        "credits": { "type": "string", "minLength": 1 },
        "completedDate": {
          "$ref": "#/$defs/yearMonth",
          "description": "Date the moment was passed. Omit if the moment was not completed."
        }
      }
    },
    "course": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "code", "institution", "credits"],
      "properties": {
        "name": { "$ref": "#/$defs/localizedString" },
        "code": { "type": "string", "minLength": 1 },
        "institution": { "$ref": "#/$defs/localizedString" },
        "credits": { "type": "string", "minLength": 1 },
        "startDate": { "$ref": "#/$defs/yearMonth" },
        "completedDate": {
          "$ref": "#/$defs/yearMonth",
          "description": "Date the course was passed. Omit when the course was only partially completed; the latest `moments[].completedDate` is used in its place for layout/timeline purposes."
        },
        "engagement": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 1,
          "description": "Study pace as a fraction of full-time (e.g. 1 = full-time, 0.5 = half-time, 0.25 = quarter-time). Used together with credits to derive a start date when startDate is omitted."
        },
        "remote": {
          "type": "boolean",
          "description": "Whether the course was delivered remotely (online/distance)."
        },
        "completed": {
          "type": "boolean",
          "description": "Whether the course was fully completed. Defaults to true. Set to false to render an 'Incomplete' pill."
        },
        "moments": {
          "type": "array",
          "minItems": 1,
          "description": "Sub-parts (Swedish: \"moment\") that make up the course. Use to break down vague course names or to record courses that were only partially completed.",
          "items": { "$ref": "#/$defs/courseMoment" }
        },
        "skills": { "$ref": "#/$defs/stringList" }
      }
    },
    "skillGroup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "label", "items"],
      "properties": {
        "key": { "type": "string", "minLength": 1 },
        "label": { "$ref": "#/$defs/localizedString" },
        "items": { "$ref": "#/$defs/stringList" }
      }
    },
    "stringList": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "spokenLanguage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "level"],
      "properties": {
        "name": { "$ref": "#/$defs/localizedString" },
        "level": { "$ref": "#/$defs/localizedString" }
      }
    }
  }
}
